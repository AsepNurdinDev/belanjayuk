# =============================================================
# .env.example — Auth Service
# Copy ke .env: cp .env.example .env
# =============================================================

# App
APP_ENV=development
APP_PORT=8001
APP_GRPC_PORT=9001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=auth_db
DB_USER=postgres
DB_PASSWORD=281205
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# JWT — generate dengan: openssl rand -hex 32
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=168h

# Google OAuth
# Buat di: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8001/api/v1/auth/google/callback

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/